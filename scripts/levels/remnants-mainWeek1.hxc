package funkin.remnants.levels;

import funkin.ui.story.Level;

class RemnantsWeekLevel extends Level
{
  function new()
  {
    super('remnants-mainWeek1');
  }

  // Reveal the name after beating the week ;)
  override function getSongDisplayNames(difficultyId:String):Array<String>
  {
    return Save.instance.hasBeatenSong('remnants') ? ["Remnants!"] : ["???"];
  }

  override function getDifficulties():Array<String>
  {
    return Constants.DEFAULT_DIFFICULTY_LIST;
  }
}
