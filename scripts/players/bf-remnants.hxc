package funkin.remnants.players;

import funkin.ui.freeplay.charselect.PlayableCharacter;
import funkin.save.Save;

class BFRemnantsPlayableCharacter extends PlayableCharacter
{
  public function new(charId:String)
  {
    if (charId == 'unknown')
    {
      charId = 'bf-remnants';
    }

    super(charId);
  }

  override public function isUnlocked():Bool
  {
    return Save.instance.hasBeatenSong('remnants');
  }
}
