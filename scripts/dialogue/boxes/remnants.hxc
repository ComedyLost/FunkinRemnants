package funkin.remnants.dialogue.boxes;

import funkin.play.cutscene.dialogue.DialogueBox;
import haxe.ds.StringMap;

class RemnantsDialogueBox extends DialogueBox
{
  final DIALOGUE_NOISES:StringMap<Dynamic> = [
    'luis-remnants' =>
    {
      noises: ['dialogueNoises/luisText'],
      volume: 0.6
    },
    'roxanne-remnants' =>
    {
      noises: ['dialogueNoises/roxanneText'],
      volume: 0.6
    },
    'bf-remnants' =>
    {
      noises: [for (i in 0...5) 'dialogueNoises/bfNoise/BF_$i'],
      volume: 0.8
    },
    'gf-remnants' =>
    {
      noises: [for (i in 0...5) 'dialogueNoises/gfNoise/GF_$i'],
      volume: 0.9
    },
    'proto-bf' =>
    {
      noises: [for (i in 0...5) 'dialogueNoises/protoBf/badnoise$i'],
      volume: 0.45
    },
    'proto-gf' =>
    {
      noises: [for (i in 0...5) 'dialogueNoises/protoGf/GF_$i'],
      volume: 0.65
    },
    'default' =>
    {
      noises: ['week6:pixelText'],
      volume: 0.6
    }
  ];

  public var cachedNoises:StringMap<Array<String>> = [];

  function new()
  {
    super('remnants');
  }

  override public function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);

    cachedNoises = new StringMap();
    for (key in DIALOGUE_NOISES.keys())
    {
      var data:Dynamic = DIALOGUE_NOISES.get(key);
      cachedNoises.set(key, [for (sound in data.noises) getNoise(sound, data)]);
    }
  }

  function getNoise(sound:String, data:Dynamic):FunkinSound
  {
    var library:String = Paths.getLibrary(sound);
    if (library == 'preload') library = null;

    var key:String = Paths.stripLibrary(sound);
    var sound:String = Paths.sound(key, library);
    return FunkinSound.load(sound, data.volume);
  }

  override function applyAnimationOffsets(name:String):Void
  {
    super.applyAnimationOffsets(name);

    this.textDisplay.x = this.globalOffsets[0] + this.originalPosition[0] + this._data.text.offsets[0];
    this.textDisplay.y = this.globalOffsets[1] + this.originalPosition[1] + this._data.text.offsets[1];
  }

  override function loadText():Void
  {
    super.loadText();
    this.textDisplay.sounds = null;
  }

  override public function setText(newText:String):Void
  {
    changeTextVoice(PlayState.instance?.currentConversation);
    super.setText(newText);
  }

  override public function onDialogueLine(event:DialogueScriptEvent):Void
  {
    FunkinSound.playOnce(Paths.sound('clickText'), 0.6);
    super.onDialogueLine(event);
  }

  function changeTextVoice(conversation:Conversation)
  {
    var sounds:Array<FunkinSound> = cachedNoises.get(conversation.currentSpeaker?.id ?? 'default');
    if (sounds == null) sounds = cachedNoises.get('default');

    this.textDisplay.sounds = sounds;
  }
}
