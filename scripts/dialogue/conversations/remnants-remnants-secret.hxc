import funkin.play.cutscene.dialogue.Conversation;
import funkin.audio.FunkinSound;

class RemnantsRemnantsSecretConversation extends Conversation
{
  var comedic:FunkinSound;

  function new()
  {
    super('remnants-remnants-secret');
  }

  override function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);
    comedic = FunkinSound.load(Paths.music('secret/comedic'), 1);
  }

  override function showCurrentSpeaker():Void
  {
    if (comedic?.stop) comedic.play();

    super.showCurrentSpeaker();

    switch (currentSpeaker.id)
    {
      case 'bf-remnants-comedic':
        FunkinSound.playOnce(Paths.sound('gameplay/secret/secret', "shared"), 1);
        comedic.play();

      case 'proto-gf':
        comedic.stop();
    }
  }
}
