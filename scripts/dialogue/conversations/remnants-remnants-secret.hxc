package funkin.remnants.dialogue.conversations;

import funkin.play.cutscene.dialogue.Conversation;
import funkin.audio.FunkinSound;

class RemnantsRemnantsSecretConversation extends Conversation
{
  var musicStart:FunkinSound;
  var musicLoop:FunkinSound;

  function new()
  {
    super('remnants-remnants-secret');
  }

  override function setupMusic():Void
  {
    musicStart = FunkinSound.load(Paths.music('secret/comedic/comedicStart'), 0.3);
    musicLoop = FunkinSound.load(Paths.music('secret/comedic/comedic'), 0.3, true);

    musicStart.onComplete = () -> {
      musicLoop?.play(true);
      super.music = musicLoop;
    }

    super.music = musicStart;
  }

  override function showCurrentSpeaker():Void
  {
    super.showCurrentSpeaker();

    switch (currentSpeaker.id)
    {
      case 'bf-remnants-comedic':
        FunkinSound.playOnce(Paths.sound('gameplay/secret/secret', "shared"), 1);
        this.music.play();

      case 'proto-gf':
        this.music.stop();
    }
  }
}
