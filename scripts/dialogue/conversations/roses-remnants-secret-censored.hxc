package funkin.remnants.dialogue.conversations;

class RosesRemnantsSecretCensoredConversation extends RosesRemnantsSecretConversation
{
  function new()
  {
    super('roses-remnants-secret-censored');
  }

  override function showCurrentSpeaker():Void
  {
    super.showCurrentSpeaker();

    switch (currentSpeaker.id)
    {
      case 'senpai-remnants-angry-shut':
        FunkinSound.playOnce(Paths.sound('shut', "week6"), 1);
    }
  }
}
