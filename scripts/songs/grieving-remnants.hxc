import funkin.play.song.Song;
import funkin.save.Save;
import funkin.play.PlayState;
import funkin.util.FlxTweenUtil;
import flixel.tweens.FlxTween;
import flixel.tweens.FlxEase;
import funkin.audio.FunkinSound;
import flixel.util.FlxTimer;
import funkin.util.SongSequence;
import funkin.Conductor;
#if mobile
import funkin.mobile.input.ControlsHandler;
#end

class GrievingRemnantsSong extends Song
{
  var utterShock:Bool = false;
  var playedDialogue:Bool = false;

  var fadeOut:Bool = false;
  var emotional:Bool = false;
  var sequence:SongSequence;

  public function new()
  {
    super('grieving-remnants');
  }

  public override function isSongNew(currentDifficulty:String, currentVariation:String):Bool
  {
    if (currentDifficulty == 'easy' || currentDifficulty == 'normal' || currentDifficulty == 'hard')
    {
      return !Save.instance.hasBeatenSong(this.id, null, '');
    }
    return false;
  }

  function onCountdownStart(event:ScriptEvent):Void
  {
    super.onCountdownStart(event);

    if (!PlayState.instance.disableKeys) PlayState.instance.disableKeys = true;
    if (PlayState.instance.isChartingMode && !playedDialogue) playedDialogue = true;

    if (!playedDialogue)
    {
      trace('Pausing countdown to play dialogue... (`grieving-remnants`)');
      playedDialogue = true;
      event.cancel();

      FlxTimer.wait(1, () -> {
        PlayState.instance.disableKeys = false;
        PlayState.instance.startConversation('grieving-remnants');
      });
    }

    var currentStage:Stage = PlayState.instance.currentStage;

    if (emotional)
    {
      for (character in currentStage.characters.iterator())
      {
        FlxTween.cancelTweensOf(character);
        character.alpha = 1;
      }

      for (dataProp in currentStage._data.props)
      {
        var propSprite:StageProp = currentStage.getNamedProp(dataProp.name);
        FlxTween.cancelTweensOf(propSprite);

        propSprite.x = dataProp.position[0];
        propSprite.y = dataProp.position[1];

        switch (dataProp.scale)
        {
          case Left(value):
            propSprite.scale.set(value, value);

          case Right(values):
            propSprite.scale.set(values[0], values[1]);
        }
        propSprite.updateHitbox();

        propSprite.alpha = dataProp.alpha;

        propSprite.scrollFactor.x = dataProp.scroll[0];
        propSprite.scrollFactor.y = dataProp.scroll[1];
      }

      emotional = false;
    }

    utterShock = FlxG.random.bool(1);
  }

  function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);

    fadeOut = false;
    emotional = false;

    playedDialogue = false;

    #if !mobile
    if (!Preferences.downscroll) PlayState.instance.comboPopUps.offsets = [550, 350]; // Upscroll PC Offset

    if (Preferences.downscroll) PlayState.instance.comboPopUps.offsets = [550, -190]; // Downscroll PC Offset
    #else
    if (Preferences.controlsScheme == "Arrows"
      && !ControlsHandler.usingExternalInputDevice) PlayState.instance.comboPopUps.offsets = [30, 350]; // Middle Mobile Offset

    if (!Preferences.downscroll
      && Preferences.controlsScheme == "Arrows"
      && ControlsHandler.usingExternalInputDevice) PlayState.instance.comboPopUps.offsets = [725, -350]; // Upscroll Side Mobile Offset

    if (Preferences.downscroll
      && Preferences.controlsScheme == "Arrows"
      && ControlsHandler.usingExternalInputDevice) PlayState.instance.comboPopUps.offsets = [725, -190]; // Downscroll Side Mobile Offset
    #end
  }

  function onSongRetry(event:ScriptEvent)
  {
    super.onSongRetry(event);

    FlxTween.cancelTweensOf(PlayState.instance.camHUD);
    if (!PlayState.instance.disableKeys) PlayState.instance.disableKeys = true;
  }

  function onGameOver(event:ScriptEvent):Void
  {
    super.onGameOver(event);
    sequence?.destroy();

    // Makes sure the game over shows during the flashbacks
    if (PlayState.instance.currentStage.getBoyfriend().alpha < 1) PlayState.instance.currentStage.getBoyfriend().alpha = 1;

    FlxTween.cancelTweensOf(PlayState.instance.camHUD);
    PlayState.instance.camHUD.alpha = 0;
    fadeOut = false;
    emotional = true;
  }

  function onPause(event:ScriptEvent):Void
  {
    super.onPause(event);
    var playState:PlayState = PlayState.instance;
    var stage:Stage = playState?.currentStage;

    var props:Array<Dynamic> = [for (i in stage?.characters?.iterator() ?? []) i];

    for (dataProp in stage?._data.props)
    {
      var prop:StageProp = stage.getNamedProp(dataProp.name);
      props.push(prop);
    }

    for (i in props)
    {
      FlxTweenUtil.pauseTweensOf(i);
    }
  }

  function onResume(event:ScriptEvent):Void
  {
    super.onResume(event);
    var playState:PlayState = PlayState.instance;
    var stage:Stage = playState?.currentStage;

    var props:Array<Dynamic> = [for (i in stage?.characters?.iterator() ?? []) i];

    for (dataProp in stage?._data.props)
    {
      var prop:StageProp = stage.getNamedProp(dataProp.name);
      props.push(prop);
    }

    for (i in props)
    {
      FlxTweenUtil.resumeTweensOf(i);
    }
  }

  function onNoteHit(event:HitNoteScriptEvent)
  {
    super.onNoteHit(event);

    if (PlayState.instance.currentStage == null) return;
    if (!event.note.noteData.getMustHitNote() && utterShock)
    {
      event.cancel();
      PlayState.instance.currentStage.getDad().playAnimation("shocked", false, true);
      PlayState.instance.vocals.opponentVolume = 0;
    }
  }

  function onSongLoaded(event:SongLoadScriptEvent)
  {
    sequence?.destroy();

    var sequenceData = [
      {
        time: Conductor.instance.getBeatTimeInMs(0) / 1000,
        callback: () -> {
          PlayState.instance.camHUD.alpha = 0;
        }
      },

      // Hi hi Hud
      {
        time: Conductor.instance.getBeatTimeInMs(26) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.camHUD, {alpha: 1}, 2.57,
            {
              ease: FlxEase.linear,
              onComplete: function(_) {
                fadeOut = true;
                PlayState.instance.disableKeys = false;
              }
            });
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(32) / 1000,
        callback: () -> {
          if (utterShock)
          {
            // She got an utter shock.
            FunkinSound.playOnce(Paths.sound('gameplay/secret/shock'), 1);
          }
        }
      },

      // Fade em all out
      {
        time: Conductor.instance.getBeatTimeInMs(218) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getNamedProp('TheGrievingLands'), {alpha: 0}, 2.57);
          FlxTween.tween(PlayState.instance.currentStage.getGirlfriend(), {alpha: 0}, 2.57);
          FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 0}, 2.57);
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 0}, 2.57);
          emotional = true;
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(224) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 1}, 2.57);
          tweenMemory('Hangout', 1500, 6.5);
        }
      },

      // Fade Roxanne out and Luis in after + Memory 2
      {
        time: Conductor.instance.getBeatTimeInMs(236) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 0}, 1.71,
            {
              ease: FlxEase.linear,
              onComplete: function(_) {
                FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 1}, 1.71);
                tweenMemory('BOOBIES', -1800, 6.5);
              }
            });
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(252) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 0}, 1.71,
            {
              ease: FlxEase.linear,
              onComplete: function(_) {
                FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 1}, 1.71);
                tweenMemory('Lovers', 1500, 6.5);
              }
            });
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(268) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 0}, 1.71,
            {
              ease: FlxEase.linear,
              onComplete: function(_) {
                FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 1}, 1.71);
                tweenMemory('Singing', -2300, 6.5);
              }
            });
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(284) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 0}, 1.71);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(288) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getNamedProp('TheGrievingLands'), {alpha: 1}, 3.43);
          FlxTween.tween(PlayState.instance.currentStage.getGirlfriend(), {alpha: 1}, 3.43);
          FlxTween.tween(PlayState.instance.currentStage.getBoyfriend(), {alpha: 1}, 3.43);
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 1}, 3.43);
          emotional = false;
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(352) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getNamedProp('TheGrievingLands'), {alpha: 0}, 1.71);
          FlxTween.tween(PlayState.instance.currentStage.getGirlfriend(), {alpha: 0}, 1.71);
          emotional = true;

          var hangout:StageProp = PlayState.instance.currentStage.getNamedProp('Hangout');
          var boobies:StageProp = PlayState.instance.currentStage.getNamedProp('BOOBIES');
          for (prop in [hangout, boobies])
            prop.scale.set(5, 5);

          hangout.setPosition(-3400, 100);
          tweenMemory('Hangout', 3100, 4.2);

          boobies.setPosition(3150, 50);
          tweenMemory('BOOBIES', -3550, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(354) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.camHUD, {alpha: 0}, 1.71, {ease: FlxEase.sineIn});
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(357) / 1000,
        callback: () -> {
          var lovers:StageProp = PlayState.instance.currentStage.getNamedProp('Lovers');
          var singing:StageProp = PlayState.instance.currentStage.getNamedProp('Singing');
          for (prop in [lovers, singing])
            prop.scale.set(5, 5);

          lovers.setPosition(-3600, -50);
          tweenMemory('Lovers', 3150, 4.2);

          singing.setPosition(3100, -200);
          tweenMemory('Singing', -4200, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(362) / 1000,
        callback: () -> {
          var hangout:StageProp = PlayState.instance.currentStage.getNamedProp('Hangout');
          var boobies:StageProp = PlayState.instance.currentStage.getNamedProp('BOOBIES');

          hangout.setPosition(-3400, 100);
          tweenMemory('Hangout', 3100, 4.2);

          boobies.setPosition(3150, 50);
          tweenMemory('BOOBIES', -3550, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(367) / 1000,
        callback: () -> {
          var lovers:StageProp = PlayState.instance.currentStage.getNamedProp('Lovers');
          lovers.setPosition(-3600, -50);
          tweenMemory('Lovers', 3150, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(372) / 1000,
        callback: () -> {
          var hangout:StageProp = PlayState.instance.currentStage.getNamedProp('Hangout');
          var boobies:StageProp = PlayState.instance.currentStage.getNamedProp('BOOBIES');

          hangout.setPosition(-3400, 100);
          tweenMemory('Hangout', 3100, 4.2);

          boobies.setPosition(3150, 50);
          tweenMemory('BOOBIES', -3550, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(377) / 1000,
        callback: () -> {
          var lovers:StageProp = PlayState.instance.currentStage.getNamedProp('Lovers');
          lovers.setPosition(-3600, -50);
          tweenMemory('BOOBIES', 3150, 4.2);

          var singing:StageProp = PlayState.instance.currentStage.getNamedProp('Singing');
          singing.setPosition(3100, -200);
          tweenMemory('Singing', -4200, 4.2);
        }
      },

      {
        time: Conductor.instance.getBeatTimeInMs(384) / 1000,
        callback: () -> {
          FlxTween.tween(PlayState.instance.currentStage.getDad(), {alpha: 0}, 1.71);
          tweenMemory('Sleeping', -2300, 10);
        }
      },
    ];

    sequence = new SongSequence(sequenceData);
    sequence.startTime = 0;
  }

  function tweenMemory(propName:String, x:Float, time:Float):Void
  {
    var prop:StageProp = PlayState.instance?.currentStage?.getNamedProp(propName);
    if (prop == null) return;

    prop.alpha = 0;
    FlxTween.tween(prop, {x: x}, time);
    FlxTween.tween(prop, {alpha: 1}, time,
      {
        onComplete: (_) -> {
          prop.alpha = 0;
        }
      });
  }

  function onDestroy(event:ScriptEvent):Void
  {
    super.onDestroy(event);

    sequence?.destroy();
  }
}
